{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Subunit",
  "version": "0.3.1",
  "identifier": "ai.subunit.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Subunit",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; media-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'; frame-src 'self' https://chat.subunit.ai https://call.subunit.ai; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:7850 ws://127.0.0.1:7850 https://atlas-api.subunit.ai wss://atlas-api.subunit.ai https://auth.subunit.ai https://*.sentry.io"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "appimage",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/subunit-ai/subunit-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBNkFEMEI1RDQyMjkxNTQKUldSVWtTTFV0ZEJxR21pWXRjNkMzMnJRR1NmUUhkNnNjRWhucXhnVGI0dHIyZGpiVEtQc3lSOUUK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
