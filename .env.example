# atlas-api backend the frontend talks to. Copy to .env.local and adjust.
#
# Local dev sidecar (default if unset) — has AUTH_DEV_BYPASS, token optional:
VITE_API_BASE=http://127.0.0.1:7850
#
# Cloud (future Hetzner) — requires a Bearer token from the shell's get_auth_token:
# VITE_API_BASE=https://atlas-api.subunit.ai
